---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';

// 1️⃣ Geração das páginas estáticas
export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: {
      slug: project.id, // ✅ string (CORRETO para [slug].astro)
    },
    props: project,
  }));
}

// 2️⃣ Tipagem correta
type Props = CollectionEntry<'projects'>;
const project = Astro.props as Props;

// 3️⃣ Render do conteúdo MD/MDX
const { Content } = await render(project);

// 4️⃣ Idioma (simples, previsível, sem mágica)
const lang = Astro.url.pathname.startsWith('/en') ? 'en' : 'pt';
const localized = project.data.languages?.[lang];

// 5️⃣ Fallback defensivo (evita crash em build)
if (!localized) {
  throw new Error(`Idioma "${lang}" não encontrado em ${project.id}`);
}
---

<!-- 6️⃣ Layout SEM Fragment -->
<BlogPost
  title={localized.title}
  summary={localized.summary}
  meta={project.data.meta}
  tags={project.data.tags}
  hero={project.data.hero}
  body={localized.body}
>
  <Content />
</BlogPost>
