---
interface Props {
  title?: string;
  summary?: string;
  meta: {
    created_at: Date;
    updated_at?: Date;
  };
  hero?: ImageMetadata;

  // opcional (content collections)
  data?: {
    languages?: Record<string, {
      title?: string;
      summary?: string;
      body?: string;
      tags?: string[];
    }>;
  };

  tags?: string[];
}

const {
  title,
  summary,
  meta,
  hero,
  data,
  tags = [],
} = Astro.props;

// idioma
const lang = Astro.url.pathname.startsWith('/en') ? 'en' : 'pt';

// resolve conteúdo
const localized = data?.languages?.[lang];

const resolvedTitle = localized?.title ?? title;
const resolvedSummary = localized?.summary ?? summary;
const resolvedTags = localized?.tags ?? tags;

if (!resolvedTitle) {
  throw new Error('BlogPost: title não definido');
}
---

<html lang={lang}>
  <head>
    <BaseHead title={title} description={summary} />
    <style>
      main {
        width: calc(100% - 2em);
        max-width: 100%;
      }
      .hero-image img {
        display: block;
        margin: 0 auto;
        border-radius: 12px;
        box-shadow: var(--box-shadow);
      }
      .prose {
        width: 720px;
        max-width: calc(100% - 2em);
        margin: auto;
        padding: 1em;
      }
      .title {
        text-align: center;
      }
      .date {
        color: rgb(var(--gray));
        margin-bottom: 0.5em;
      }
    </style>
  </head>

  <body>
    <Header />

    <main>
<article>
  <h1>{resolvedTitle}</h1>

  {resolvedSummary && <p>{resolvedSummary}</p>}

  {hero && <img src={hero.src} alt={resolvedTitle} />}

  <slot />

  {meta?.created_at && (
    <time datetime={meta.created_at.toISOString()}>
      {meta.created_at.toLocaleDateString()}
    </time>
  )}
</article>
    </main>

    <Footer />
  </body>
</html>
