---
import { Image, type ImageMetadata } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  summary?: string;
  meta: {
    created_at: Date;
    updated_at?: Date;
  };
  hero?: ImageMetadata;
  tags?: string[];
  lang: 'pt' | 'en';
}

const {
  title,
  summary,
  meta,
  hero,
  tags = [],
  lang,
} = Astro.props;
---

<html lang={lang}>
  <head>
    <BaseHead title={title} description={summary} />
  </head>

  <body>
    <Header />

    <main>
      <article class="prose">
        <header>
          <h1>{title}</h1>
          {summary && <p>{summary}</p>}
        </header>

        {hero && <Image src={hero} alt={title} />}

        {/* 👇 slot com filtro de idioma */}
        <div class="content">
          <slot />
        </div>

        <style>
          /* esconde tudo */
          [data-lang] {
            display: none;
          }

          /* mostra só o idioma atual */
          [data-lang="{lang}"] {
            display: block;
          }
        </style>

        <time datetime={meta.created_at.toISOString()}>
          {meta.created_at.toLocaleDateString()}
        </time>
      </article>
    </main>

    <Footer />
  </body>
</html>
