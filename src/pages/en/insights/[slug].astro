---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';

// 1️⃣ Geração das páginas estáticas
export async function getStaticPaths() {
  const insights = await getCollection('insights');

  return insights.map((insight) => ({
    params: {
      slug: insight.id, // ✅ string (CORRETO para [slug].astro)
    },
    props: insight,
  }));
}

// 2️⃣ Tipagem correta
type Props = CollectionEntry<'insights'>;
const insight = Astro.props as Props;

// 3️⃣ Render do conteúdo MD/MDX
const { Content } = await render(insight);

// 4️⃣ Idioma (simples, previsível, sem mágica)
const lang = Astro.url.pathname.startsWith('/en') ? 'en' : 'pt';
const localized = insight.data.languages?.[lang];

// 5️⃣ Fallback defensivo (evita crash em build)
if (!localized) {
  throw new Error(`Idioma "${lang}" não encontrado em ${insight.id}`);
}
---

<!-- 6️⃣ Layout SEM Fragment -->
<BlogPost
  title={localized.title}
  summary={localized.summary}
  meta={insight.data.meta}
  tags={insight.data.tags}
  hero={insight.data.hero}
>
  <Content />
</BlogPost>
