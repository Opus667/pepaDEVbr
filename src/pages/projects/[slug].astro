---
import { getCollection } from "astro:content";

// getStaticPaths deve chamar getCollection DENTRO da função
export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// Props vindas do getStaticPaths
const { entry } = Astro.props;

// Idioma padrão
const lang = "pt";
const current = entry.data.languages[lang];
---

<article>
  <h1 data-i18n="title">{current.title}</h1>
  <p data-i18n="summary">{current.summary}</p>

  {entry.data.hero && <img src={entry.data.hero} alt={current.title} />}

  <div data-i18n="body" set:html={current.body}></div>
</article>

<script define:vars={{ entry }}>
  window.__CONTENT__ = entry.data.languages;

  let active = localStorage.getItem("lang") || "pt";

  function update(lang) {
    active = lang;
    localStorage.setItem("lang", lang);

    document.querySelectorAll("[data-i18n]").forEach((el) => {
      const key = el.dataset.i18n;
      el.innerHTML = window.__CONTENT__[lang][key];
    });
  }

  window.addEventListener("langchange", (ev) => update(ev.detail));

  update(active);
</script>
